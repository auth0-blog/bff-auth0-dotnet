{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Schemes": {
      "Bearer": {
        "Authority": "https://YOUR_DOMAIN",
        "ValidAudiences": [ "YOUR_API_AUDIENCE" ],
        "ValidIssuer": "YOUR_DOMAIN"
      }
    }
  }
}